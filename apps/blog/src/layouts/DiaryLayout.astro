---
import BaseLayout from './BaseLayout.astro';
import type { DiaryEntry } from '../lib/diaries';
import { formatDate } from '../lib/posts';

interface Props {
  entry: DiaryEntry;
}

const { entry } = Astro.props;
---

<BaseLayout title={entry.data.title} description={entry.data.description} type="article">
  <article class="container article diary-article">
    <header class="article-header">
      <p class="eyebrow">Diary</p>
      <h1>{entry.data.title}</h1>
      <p class="article-description">{entry.data.description}</p>
      <div class="post-meta">
        <time datetime={entry.data.publishedAt.toISOString()}>
          {formatDate(entry.data.publishedAt)}
        </time>
        {entry.data.draft && <span class="draft-badge">초안</span>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="article-footer">
      <a href="/diary">← 모든 일기 보기</a>
    </footer>
  </article>
</BaseLayout>
