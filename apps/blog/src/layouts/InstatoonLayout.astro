---
import BaseLayout from './BaseLayout.astro';
import type { InstatoonScenario } from '../lib/instatoons';
import { formatDate } from '../lib/posts';

interface Props {
  scenario: InstatoonScenario;
}

const { scenario } = Astro.props;
---

<BaseLayout title={scenario.data.title} description={scenario.data.description} type="article">
  <article class="container article instatoon-article">
    <header class="article-header">
      <p class="eyebrow">Instagram Comic</p>
      <h1>{scenario.data.title}</h1>
      <p class="article-description">{scenario.data.description}</p>
      <div class="post-meta">
        <time datetime={scenario.data.publishedAt.toISOString()}>
          {formatDate(scenario.data.publishedAt)}
        </time>
        {scenario.data.draft && <span class="draft-badge">초안</span>}
      </div>
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="article-footer">
      <a href="/instatoon">← 모든 시나리오 보기</a>
    </footer>
  </article>
</BaseLayout>
