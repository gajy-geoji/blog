---
import BaseLayout from './BaseLayout.astro';
import { formatDate, type BlogPost } from '../lib/posts';

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
---

<BaseLayout title={post.data.title} description={post.data.description} type="article">
  <article class="container article">
    <header class="article-header">
      <p class="eyebrow">Article</p>
      <h1>{post.data.title}</h1>
      <p class="article-description">{post.data.description}</p>
      <div class="post-meta">
        <time datetime={post.data.publishedAt.toISOString()}>
          {formatDate(post.data.publishedAt)}
        </time>
        {post.data.updatedAt && (
          <span>수정 {formatDate(post.data.updatedAt)}</span>
        )}
        {post.data.draft && <span class="draft-badge">초안</span>}
      </div>
      {post.data.tags.length > 0 && (
        <ul class="tag-list" aria-label="태그">
          {post.data.tags.map((tag) => <li>#{tag}</li>)}
        </ul>
      )}
    </header>
    <div class="prose">
      <slot />
    </div>
    <footer class="article-footer">
      <a href="/posts">← 모든 글 보기</a>
    </footer>
  </article>
</BaseLayout>
