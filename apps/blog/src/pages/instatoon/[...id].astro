---
import { render } from 'astro:content';
import InstatoonLayout from '../../layouts/InstatoonLayout.astro';
import { getInstatoonSlug, getPublishedInstatoons } from '../../lib/instatoons';

export async function getStaticPaths() {
  const scenarios = await getPublishedInstatoons();

  return scenarios.map((scenario) => ({
    params: { id: getInstatoonSlug(scenario) },
    props: { scenario },
  }));
}

const { scenario } = Astro.props;
const { Content } = await render(scenario);
---

<InstatoonLayout scenario={scenario}>
  <Content />
</InstatoonLayout>
