---
import InstatoonCard from '../../components/InstatoonCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedInstatoons } from '../../lib/instatoons';

const scenarios = await getPublishedInstatoons();
---

<BaseLayout title="인스타툰" description="일상에서 건져 올린 인스타툰 시나리오 목록">
  <section class="container page-header">
    <p class="eyebrow">Instagram Comic</p>
    <h1>인스타툰 시나리오</h1>
    <p>총 {scenarios.length}개의 시나리오가 있습니다.</p>
  </section>
  <section class="container section section-compact">
    <div class="post-list">
      {scenarios.map((scenario) => <InstatoonCard scenario={scenario} />)}
    </div>
  </section>
</BaseLayout>
