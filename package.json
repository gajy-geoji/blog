{
  "name": "gajy-geoji-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @gajy-geoji/blog dev",
    "start": "pnpm --filter @gajy-geoji/blog start",
    "build": "pnpm --filter @gajy-geoji/blog build",
    "preview": "pnpm --filter @gajy-geoji/blog preview",
    "check": "pnpm --filter @gajy-geoji/blog check",
    "build:all": "pnpm -r --if-present build",
    "check:all": "pnpm -r --if-present check"
  }
}
